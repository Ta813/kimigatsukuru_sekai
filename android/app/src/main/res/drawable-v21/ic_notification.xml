<?xml version="1.0" encoding="utf-8"?>
<!--
  通知用スモールアイコン（ベクター形式）
  ・Android 5.0（API 21）以降の要件に従い、白色単色・透過背景
  ・カラーPNGは背景が黒くなる / NullPointerException の原因になるため
    必ずこのXML形式を使用すること
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="@android:color/white">

  <!--
    星型のシンプルなアイコン（5角形の星）
    アプリのキャラクターのイメージに合わせたスター形状
  -->
  <path
      android:fillColor="#FFFFFF"
      android:pathData="M12,2
        L14.09,8.26
        L21,9.27
        L16,14.14
        L17.18,21.02
        L12,17.77
        L6.82,21.02
        L8,14.14
        L3,9.27
        L9.91,8.26
        Z" />

</vector>
